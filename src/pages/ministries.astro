---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHero from '../components/PageHero.astro';
import { withBase } from '../lib/urls';
---

<BaseLayout title="Ministries" description="Explore children's, young adult, women's, men's, worship, dance, and creative arts ministries at Temple Aviv Judea.">
  <PageHero eyebrow="Mishpachah in motion" title="Bring your gifts. Find your people." intro="Community grows when we pray together, learn together, create together, and serve one another beyond Shabbat morning." accent="coral" />

  <section class="section ministries-grid-section">
    <div class="shell ministry-card-grid" data-stagger>
      <article class="ministry-card has-photo coral-card"><img src={withBase('/images/live/shabbat-school.webp')} alt="The colorful Temple Aviv Judea Shabbat School welcome display" width="1800" height="1178" loading="lazy" /><div class="ministry-card-body"><span class="eyebrow">The next generation</span><h2>Children</h2><p>Shabbat School gives children a dedicated time to learn important truths from G-d’s Word in a caring setting suited to their age.</p></div></article>
      <article class="ministry-card has-photo blue-card"><img src={withBase('/images/live/mya.webp')} alt="Temple Aviv Judea teens and young adults gathered together" width="1085" height="783" loading="lazy" /><div class="ministry-card-body"><span class="eyebrow">Growing in purpose</span><h2>Young Adults</h2><p>A place to build lasting friendships, deepen faith, and discover how to serve G-d with clarity and courage.</p></div></article>
      <article class="ministry-card has-photo gold-card"><img src={withBase('/images/live/womens-group.webp')} alt="The Temple Aviv Judea women’s group" width="1800" height="1350" loading="lazy" /><div class="ministry-card-body"><span class="eyebrow">Shared life</span><h2>Women & Men</h2><p>Fellowship, prayer, food, encouragement, and honest conversation create space to grow together through every season.</p></div></article>
      <article class="ministry-card has-photo teal-card"><img src={withBase('/images/live/dance-ministry.webp')} alt="Mosaic artwork of a Messianic Jewish congregation participating in Davidic dance" width="1080" height="1080" loading="lazy" /><div class="ministry-card-body"><span class="eyebrow">Worship in motion</span><h2>Music & Davidic Dance</h2><p>Musicians, singers, and dancers help lead expressive Messianic Jewish worship rooted in Scripture and rich tradition.</p></div></article>
      <article class="ministry-card purple-card wide-card"><div class="artist-thumbnails"><img src={withBase('/images/live/artist-gallery-1.webp')} alt="Congregational artwork of two women in a vivid blue and gold palette" width="487" height="640" loading="lazy" /><img src={withBase('/images/live/artist-gallery-2.webp')} alt="Congregational artwork depicting Moses and the tablets" width="929" height="1200" loading="lazy" /></div><div><span class="eyebrow eyebrow-light">Created to create</span><h2>Creative Arts</h2><p>Visual art, drama, music, and movement help the community tell the biblical story with imagination, beauty, and joy.</p></div><a class="button button-ghost-light" href={withBase('/artists/')}>Visit the artists’ gallery</a></article>
    </div>
  </section>

  <section class="cta-section">
    <div class="shell cta-inner" data-stagger><div><span class="eyebrow">Not sure where to begin?</span><h2>Start with one Shabbat.</h2><p>Meet the people, share a meal, and discover where your gifts can come alive.</p></div><a class="button" href={withBase('/visit/')}>Plan your visit</a></div>
  </section>
</BaseLayout>
