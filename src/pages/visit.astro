---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHero from '../components/PageHero.astro';
import SiteIcon from '../components/SiteIcon.astro';
import { site } from '../data/site';
import { withBase } from '../lib/urls';
---

<BaseLayout title="Prepare for Shabbat" description="Prepare for your first Shabbat visit to Temple Aviv Judea in Fullerton. Find service times, what to expect, family information, meal guidance, and ways to connect.">
  <PageHero eyebrow="Prepare for Shabbat" title="Come curious. You are welcome." intro="Whether Messianic Jewish worship is familiar or completely new, here is what to expect so you and your family can arrive at ease." accent="coral" />

  <section class="mosaic-feature mosaic-coral" aria-label="Shabbat artwork">
    <div class="shell mosaic-frame" data-reveal="wipe"><img src={withBase('/images/shofar-jerusalem-mosaic.webp')} alt="Mosaic artwork of a worshipper sounding the shofar over Jerusalem" width="853" height="309" /></div>
  </section>

  <section class="section">
    <div class="shell visit-grid" data-stagger>
      <div class="sticky-card">
        <span class="eyebrow">Saturday rhythm</span>
        <h2>Make a day of it.</h2>
        <div class="vertical-schedule">
          {site.schedule.map((item, index) => (
            <div class="vertical-schedule-item">
              <span class="timeline-dot">{index + 1}</span>
              <div><strong>{item.time}</strong><h3>{item.label}</h3><p>{item.note}</p></div>
            </div>
          ))}
        </div>
        <div class="button-row">
          <a class="button button-gold" href={site.address.maps} target="_blank" rel="noreferrer"><SiteIcon name="map-pin" size={18} /> Get directions</a>
          <a class="button button-ghost-light" href={site.youtube} target="_blank" rel="noreferrer"><SiteIcon name="brand-youtube" size={18} /> Watch livestream</a>
        </div>
      </div>

      <div class="content-stack">
        <article class="content-card">
          <h3>Who will I meet?</h3>
          <p>Our mishpachah is a diverse community of Jewish and Gentile believers from many ethnicities and faith backgrounds. What draws us together is love—for G-d, for one another, and for every person who walks through the door.</p>
        </article>
        <article class="content-card feature-card">
          <span class="card-kicker">What happens in a service?</span>
          <h2>Ancient patterns, wholehearted praise.</h2>
          <p>Our Shabbat gathering weaves together traditional Jewish liturgy, musical worship, singing, and Davidic dance. We bless our children, hear a message from Scripture through a Jewish perspective, and close with the Aaronic Blessing.</p>
        </article>
        <article class="content-card">
          <h3>What should I wear?</h3>
          <p>Come presentable, modest, and comfortable. You do not need special clothing or prior knowledge of Jewish tradition to participate.</p>
        </article>
        <article class="content-card">
          <h3>What about children?</h3>
          <p>Children are part of our community. We offer Shabbat School during the morning and have a crying room available for families with little ones.</p>
        </article>
        <article class="content-card">
          <h3>Can I stay for lunch?</h3>
          <p>Absolutely. People visiting for the first time are our guests at the weekly Oneg potluck. If you choose to bring food, please do not bring pork or shellfish.</p>
        </article>
        <article class="content-card">
          <h3>What happens after the service?</h3>
          <p>Stay for Oneg and conversation, then join Rabbi’s Corner to explore the weekly Torah portion and ask questions. Community life also includes a monthly women’s gathering, Davidic dance instruction, and opportunities to serve one another and our neighbors.</p>
        </article>
        <article class="content-card accent-card">
          <h3>Let us welcome you personally.</h3>
          <p>Rabbi Corey would be glad to meet you over lunch or by appointment and answer your questions. First-time visitors may also receive a hospitality package. Call and leave a message, or send an email, and we will help you feel prepared.</p>
          <div class="inline-links"><a href={site.phoneHref}>{site.phone}</a><a href={`mailto:${site.email}`}>{site.email}</a></div>
        </article>
      </div>
    </div>
  </section>

  <section class="location-section">
    <div class="shell location-grid" data-stagger>
      <div>
        <span class="eyebrow eyebrow-light">Find us in Fullerton</span>
        <h2 class="location-address"><span>{site.address.street}</span><span>{site.address.city}</span></h2>
        <p>Just a few blocks from downtown Fullerton on Commonwealth Avenue.</p>
      </div>
      <a class="button button-gold" href={site.address.maps} target="_blank" rel="noreferrer"><SiteIcon name="map-pin" size={18} /> Open in Google Maps</a>
    </div>
  </section>
</BaseLayout>
