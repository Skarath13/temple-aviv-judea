---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHero from '../components/PageHero.astro';
import SiteIcon from '../components/SiteIcon.astro';
import { site } from '../data/site';
---

<BaseLayout title="Give" description="Support the worship, teaching, community, and outreach of Temple Aviv Judea.">
  <PageHero eyebrow="Generosity with purpose" title="Help the vision grow." intro="Your giving supports a lasting Messianic Jewish witness in Fullerton through worship, teaching, hospitality, and care for the community." accent="gold" />
  <section class="mosaic-feature mosaic-gold" aria-label="Remembrance artwork">
    <div class="shell mosaic-frame"><img src="/images/remembrance-mosaic.webp" alt="Mosaic artwork of a cup, broken bread, sunrise, and three crosses" width="853" height="298" /></div>
  </section>
  <section class="section give-section">
    <div class="shell give-grid">
      <div><span class="eyebrow">Offering & mishpachah</span><h2>Give with purpose. Care for the family.</h2><p class="lead">You are part of our mishpachah, our family. Together, we care for people who need physical, spiritual, and financial support.</p><p>Your offering helps sustain Shabbat worship, biblical teaching, hospitality, ministry, and outreach. Donations are completed directly through Temple Aviv Judea’s existing PayPal account.</p><a class="button button-large" href={site.giving} target="_blank" rel="noreferrer">Donate securely with PayPal <SiteIcon name="external-link" size={17} /></a><p class="security-note">PayPal opens in a new tab. This website never sees or stores your payment details.</p></div>
      <aside class="give-card"><img class="give-photo" src="/images/give-art.webp" alt="Mosaic artwork of the Temple and Western Wall with hands holding a golden heart and the words Give, Honor Hashem with your firstfruits" width="1280" height="853" /><div class="give-card-body"><span class="eyebrow eyebrow-light">Your generosity supports</span><ul><li><span>01</span>Shabbat worship & biblical teaching</li><li><span>02</span>Children and young adult ministries</li><li><span>03</span>Community meals & hospitality</li><li><span>04</span>Creative arts & dance</li><li><span>05</span>Local and Jewish outreach</li></ul></div></aside>
    </div>
  </section>
</BaseLayout>
