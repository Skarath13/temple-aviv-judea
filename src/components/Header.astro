---
import { navItems, site } from '../data/site';
import { withBase, withoutBase } from '../lib/urls';
import SiteIcon from './SiteIcon.astro';

interface Props { currentPath: string }
const { currentPath } = Astro.props;
const localPath = withoutBase(currentPath);
const isCurrent = (href: string) => href === '/' ? localPath === '/' : localPath.startsWith(href);
---

<header class="site-header">
  <div class="shell header-main">
    <a class="brand" href={withBase('/')} aria-label={`${site.name} home`}>
      <img class="brand-logo" src={withBase('/images/taj-logo.png')} alt="" width="512" height="512" />
      <span class="brand-copy">
        <strong>{site.name}</strong>
        <small>A Messianic Jewish Congregation</small>
      </span>
    </a>

    <nav class="desktop-nav" aria-label="Primary navigation">
      {navItems.map((item) => (
        <a href={withBase(item.href)} aria-current={isCurrent(item.href) ? 'page' : undefined}>{item.label}</a>
      ))}
    </nav>

    <div class="header-actions">
      <a class="text-link desktop-only" href={withBase('/give/')}>Give</a>
      <a class="button button-small button-gold" href={withBase('/visit/')}>Plan a visit</a>
    </div>

    <details class="mobile-menu">
      <summary aria-label="Open navigation"><span></span><span></span><span></span></summary>
      <nav aria-label="Mobile navigation">
        {navItems.map((item) => (
          <a href={withBase(item.href)} aria-current={isCurrent(item.href) ? 'page' : undefined}>{item.label}</a>
        ))}
        <a href={withBase('/give/')}>Give</a>
        <a class="mobile-youtube-live" href={site.youtube} target="_blank" rel="noreferrer"><span class="live-dot" aria-hidden="true"></span><SiteIcon name="brand-youtube" size={21} /><span><strong>Watch live on YouTube</strong><small>Saturdays · 11:00 AM PT</small></span></a>
      </nav>
    </details>
  </div>
</header>
