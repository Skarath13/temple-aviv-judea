---
import type { UpcomingEvent } from '../data/events';
import { withBase } from '../lib/urls';
import SiteIcon from './SiteIcon.astro';

interface Props {
  events: readonly UpcomingEvent[];
}

const { events } = Astro.props;
const visibleEvents = events.slice(0, 3);
const formatDate = (startsAt: string) => new Intl.DateTimeFormat('en-US', {
  month: 'long',
  day: 'numeric',
  year: 'numeric',
  timeZone: 'America/Los_Angeles',
}).format(new Date(startsAt));
const imageSource = (src: string) => /^https?:\/\//.test(src) ? src : withBase(src);
---

{visibleEvents.length > 0 && (
  <section class="section upcoming-events-section" aria-labelledby="upcoming-events-title">
    <div class="shell">
      <div class="section-heading light" data-reveal>
        <span class="eyebrow eyebrow-light">Gather with us</span>
        <h2 id="upcoming-events-title">Upcoming events.</h2>
        <p>Special gatherings, celebrations, and opportunities to share life together.</p>
      </div>
      <div class="upcoming-events-grid" data-stagger>
        {visibleEvents.map((event) => (
          <article class="upcoming-event-card">
            <div class="upcoming-event-image">
              <img src={imageSource(event.image.src)} alt={event.image.alt} width={event.image.width} height={event.image.height} loading="lazy" />
            </div>
            <div class="upcoming-event-copy">
              <span class="event-date"><SiteIcon name="calendar-event" size={19} /> {formatDate(event.startsAt)}</span>
              <h3>{event.title}</h3>
              <p>{event.summary}</p>
              <span class="event-location"><SiteIcon name="map-pin" size={18} /> {event.location}</span>
              {event.detailsUrl && <a class="button button-gold" href={event.detailsUrl}>Event details</a>}
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>
)}
