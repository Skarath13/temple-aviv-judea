---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import SiteIcon from '../components/SiteIcon.astro';
import '../styles/global.css';
import { site } from '../data/site';
import { withBase } from '../lib/urls';

interface Props {
  title?: string;
  description?: string;
  image?: string;
  robots?: string;
}

const {
  title = site.name,
  description = site.description,
  image = '/og.png',
  robots = 'index, follow',
} = Astro.props;
const pageTitle = title === site.name ? title : `${title} | ${site.name}`;
const canonical = new URL(Astro.url.pathname, Astro.site);
const socialImage = new URL(withBase(image), Astro.site);
const eagleLakeFont = withBase('/fonts/eagle-lake-regular.ttf');
const eagleLakeFontFace = `@font-face{font-family:'Eagle Lake';src:url('${eagleLakeFont}') format('truetype');font-display:swap;font-style:normal;font-weight:400;}`;
const structuredData = {
  '@context': 'https://schema.org',
  '@type': 'PlaceOfWorship',
  name: site.name,
  url: new URL(withBase('/'), Astro.site).href,
  image: new URL(withBase('/images/taj-logo.png'), Astro.site).href,
  email: site.email,
  telephone: site.phone,
  address: {
    '@type': 'PostalAddress',
    streetAddress: site.address.street,
    addressLocality: 'Fullerton',
    addressRegion: 'CA',
    postalCode: '92831',
    addressCountry: 'US',
  },
};
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <meta name="theme-color" content="#03182a" />
    <meta name="theme-color" content="#071f37" media="(prefers-color-scheme: light)" />
    <meta name="theme-color" content="#03182a" media="(prefers-color-scheme: dark)" />
    <meta name="color-scheme" content="light" />
    <meta name="mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />
    <meta name="apple-mobile-web-app-title" content={site.shortName} />
    <script is:inline>
      if ('IntersectionObserver' in window && !window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
        document.documentElement.classList.add('motion-ready');
      }
    </script>
    <meta name="description" content={description} />
    <meta name="robots" content={robots} />
    <link rel="canonical" href={canonical} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="preload" href={eagleLakeFont} as="font" type="font/ttf" crossorigin />
    <style is:inline set:html={eagleLakeFontFace} />
    <link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;600;700&display=swap" rel="stylesheet" />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={socialImage} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={socialImage} />
    <script is:inline type="application/ld+json" set:html={JSON.stringify(structuredData)} />
    <link rel="icon" href={withBase('/favicon.png')} type="image/png" sizes="96x96" />
    <link rel="apple-touch-icon" href={withBase('/apple-touch-icon.png')} sizes="180x180" />
    <title>{pageTitle}</title>
  </head>
  <body>
    <div class="scroll-progress" aria-hidden="true"></div>
    <a class="skip-link" href="#main-content">Skip to content</a>
    <Header currentPath={Astro.url.pathname} />
    <main id="main-content">
      <slot />
    </main>
    <Footer />
    <button class="back-to-top" type="button" aria-label="Back to top" title="Back to top"><SiteIcon name="arrow-up" size={22} /></button>
    <script is:inline>
      (() => {
        const root = document.documentElement;
        if (!root.classList.contains('motion-ready')) return;

        const targets = [...document.querySelectorAll('[data-reveal], [data-stagger]')];
        const reveal = (element) => element.classList.add('is-visible');
        const observer = new IntersectionObserver((entries) => {
          for (const entry of entries) {
            if (!entry.isIntersecting) continue;
            reveal(entry.target);
            observer.unobserve(entry.target);
          }
        }, { threshold: 0.12, rootMargin: '0px 0px -7% 0px' });

        for (const target of targets) observer.observe(target);

        const revealInView = () => {
          for (const target of targets) {
            if (target.classList.contains('is-visible')) continue;
            const bounds = target.getBoundingClientRect();
            if (bounds.bottom <= 0 || bounds.top >= window.innerHeight * 0.93) continue;
            reveal(target);
            observer.unobserve(target);
          }
        };

        const progress = document.querySelector('.scroll-progress');
        let queued = false;
        const updateProgress = () => {
          const scrollable = document.documentElement.scrollHeight - window.innerHeight;
          const ratio = scrollable > 0 ? Math.min(1, Math.max(0, window.scrollY / scrollable)) : 0;
          progress?.style.setProperty('--scroll-progress', String(ratio));
          revealInView();
          queued = false;
        };
        const queueProgress = () => {
          if (queued) return;
          queued = true;
          requestAnimationFrame(updateProgress);
        };

        updateProgress();
        window.addEventListener('scroll', queueProgress, { passive: true });
        window.addEventListener('resize', queueProgress, { passive: true });
      })();
    </script>
    <script is:inline>
      (() => {
        const button = document.querySelector('.back-to-top');
        if (!button) return;

        let queued = false;
        const update = () => {
          const threshold = Math.max(560, window.innerHeight * 0.65);
          button.classList.toggle('is-visible', window.scrollY > threshold);
          queued = false;
        };
        const queueUpdate = () => {
          if (queued) return;
          queued = true;
          requestAnimationFrame(update);
        };

        button.addEventListener('click', () => {
          const reducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
          window.scrollTo({ top: 0, behavior: reducedMotion ? 'auto' : 'smooth' });
          button.blur();
        });
        update();
        window.addEventListener('scroll', queueUpdate, { passive: true });
        window.addEventListener('resize', queueUpdate, { passive: true });
      })();
    </script>
  </body>
</html>
